<button id="lang-toggle" class="text-[11px] font-mono text-[#8A8A8A] hover:text-white transition-colors border border-white/10 rounded px-2 py-1 bg-transparent cursor-pointer font-inherit" type="button" aria-label="Toggle language">
  <span class="lang-ar">EN</span>
  <span class="lang-en">عربي</span>
</button>

<script>
  const langToggle = document.getElementById("lang-toggle");
  langToggle?.addEventListener("click", () => {
    const current = localStorage.getItem("lang") || "ar";
    const next = current === "ar" ? "en" : "ar";
    localStorage.setItem("lang", next);
    window.location.reload();
  });
</script>
