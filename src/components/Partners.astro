---
import { config } from "@/config";

const roleOrder = ["official", "community-partner", "venue-host", "past-community-partner"] as const;

const roleLabelEn: Record<string, string> = {
  "official": "Official",
  "community-partner": "Community Partners",
  "venue-host": "Venue Hosts",
  "past-community-partner": "Past Partners",
};

const roleLabelAr: Record<string, string> = {
  "official": "الشريك الرسمي",
  "community-partner": "شركاء المجتمع",
  "venue-host": "مستضيفو الأماكن",
  "past-community-partner": "شركاء سابقون",
};

const roleBadgeEn: Record<string, string> = {
  "official": "Official",
  "community-partner": "Community Partner",
  "venue-host": "Venue Host",
  "past-community-partner": "Past Partner",
};

const roleBadgeAr: Record<string, string> = {
  "official": "رسمي",
  "community-partner": "شريك مجتمعي",
  "venue-host": "مستضيف",
  "past-community-partner": "شريك سابق",
};

const grouped = roleOrder
  .map((role) => ({
    role,
    partners: config.partners.filter((p) => p.role === role),
  }))
  .filter((g) => g.partners.length > 0);
---

<section id="partners" class="partners-section">
  <div class="container">
    <div class="animate-on-scroll">
      <h2 class="section-heading">
        <span class="lang-ar">الشركاء</span>
        <span class="lang-en">Partners</span>
      </h2>
      <p class="partners-subtitle">
        <span class="lang-ar">المؤسسات الداعمة لفعاليات المجتمع</span>
        <span class="lang-en">Organizations supporting our community events</span>
      </p>
    </div>

    {grouped.map((group) => (
      <div class:list={["partner-group", { "partner-group--past": group.role === "past-community-partner" }]}>
        <h3 class="partner-group-heading animate-on-scroll">
          <span class="lang-ar">{roleLabelAr[group.role]}</span>
          <span class="lang-en">{roleLabelEn[group.role]}</span>
        </h3>

        <div class:list={[
          "stagger-children",
          group.role === "official" ? "partners-grid partners-grid--official" : "partners-grid",
        ]}>
          {group.partners.map((partner) => {
            const cardIsInternal = partner.slug === "cursor";
            const cardHref = cardIsInternal ? `/partners/${partner.slug}/` : partner.url;
            return (
            <a
              href={cardHref}
              target={cardIsInternal ? undefined : "_blank"}
              rel={cardIsInternal ? undefined : "noreferrer"}
              class:list={[
                "partner-card card animate-on-scroll",
                { "partner-card--official": group.role === "official" },
                { "partner-card--past": group.role === "past-community-partner" },
              ]}
            >
              <div class="partner-header">
                <img
                  src={partner.logo}
                  alt={partner.name}
                  class:list={[
                    "partner-logo",
                    { "partner-logo--official": group.role === "official" },
                  ]}
                  loading="lazy"
                />
                <div class="partner-title">
                  <span class="partner-name">
                    <span class="lang-ar">{partner.nameAr}</span>
                    <span class="lang-en">{partner.name}</span>
                  </span>
                  <span class:list={["partner-badge", `partner-badge--${group.role}`]}>
                    <span class="lang-ar">{roleBadgeAr[group.role]}</span>
                    <span class="lang-en">{roleBadgeEn[group.role]}</span>
                  </span>
                </div>
              </div>
              <p class="partner-description">
                <span class="lang-ar">{partner.descriptionAr}</span>
                <span class="lang-en">{partner.description}</span>
              </p>
              {partner.cities.length > 0 && (
                <span class="partner-cities">
                  {partner.cities.join(", ")}
                </span>
              )}
              <svg class="partner-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 12l8-8m0 0H5m7 0v7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          );
          })}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .partners-section {
    padding: 2rem 0 2rem;
  }

  .partners-subtitle {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin: -1.25rem 0 2rem;
  }

  /* ─── Role groups ─── */

  .partner-group {
    margin-bottom: 2.5rem;
  }

  .partner-group:last-child {
    margin-bottom: 0;
  }

  .partner-group-heading {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-bottom: 1rem;
  }

  .partner-group--past {
    opacity: 0.7;
  }

  /* ─── Grid ─── */

  .partners-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .partners-grid--official {
    grid-template-columns: 1fr;
    max-width: 480px;
  }

  /* ─── Cards ─── */

  .partner-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    position: relative;
    text-decoration: none;
  }

  .partner-card--official {
    border-color: rgba(255, 255, 255, 0.12);
  }

  .partner-card--past {
    opacity: 0.65;
  }

  .partner-card--past:hover {
    opacity: 0.85;
  }

  .partner-header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .partner-logo {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .partner-logo--official {
    width: 56px;
    height: 56px;
  }

  .partner-title {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .partner-name {
    font-size: 1.05rem;
    font-weight: 700;
  }

  /* ─── Role badges ─── */

  .partner-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    width: fit-content;
    color: #999;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .partner-badge--official {
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .partner-badge--community-partner {
    color: #7dd3fc;
    background: rgba(125, 211, 252, 0.08);
    border-color: rgba(125, 211, 252, 0.15);
  }

  .partner-badge--venue-host {
    color: #86efac;
    background: rgba(134, 239, 172, 0.08);
    border-color: rgba(134, 239, 172, 0.15);
  }

  .partner-badge--past-community-partner {
    color: #6E6E6E;
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.05);
  }

  /* ─── Rest ─── */

  .partner-cities {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  .partner-description {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .partner-arrow {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    color: var(--text-tertiary);
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  html[dir="rtl"] .partner-arrow {
    right: auto;
    left: 1.5rem;
  }

  .partner-card:hover .partner-arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }
</style>
