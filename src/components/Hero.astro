---
import { t } from "@/i18n";
import type { CollectionEntry } from "astro:content";

interface Props {
  firstUpcomingEvent?: CollectionEntry<"events">;
}

const { firstUpcomingEvent } = Astro.props;
const ctaHref = firstUpcomingEvent?.data.lumaUrl ?? "#events";
---

<section class="hero">
  <div class="container hero-content">
    <!-- Decorative accent line -->
    <div class="hero-badge fade-in-up">
      <span class="badge-dot"></span>
      <span class="lang-ar">مجتمع مطورين نشط في السعودية</span>
      <span class="lang-en">Active developer community in Saudi Arabia</span>
    </div>

    <h1 class="hero-title fade-in-up fade-in-up-delay-1">
      <span class="lang-ar">{t("ar", "hero.title")}</span>
      <span class="lang-en">{t("en", "hero.title")}</span>
    </h1>

    <p class="hero-description fade-in-up fade-in-up-delay-2">
      <span class="lang-ar">{t("ar", "hero.description")}</span>
      <span class="lang-en">{t("en", "hero.description")}</span>
    </p>

    <div class="hero-actions fade-in-up fade-in-up-delay-3">
      <a href={ctaHref} class="btn btn-primary btn-lg">
        <span class="lang-ar">{t("ar", "hero.cta")}</span>
        <span class="lang-en">{t("en", "hero.cta")}</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="https://x.com/cursorsaudi" target="_blank" rel="noreferrer" class="btn btn-ghost">
        <span class="lang-ar">تابعنا على X</span>
        <span class="lang-en">Follow on X</span>
      </a>
    </div>
  </div>

  <!-- Decorative gradient orb -->
  <div class="hero-glow" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    padding: 8rem 0 6rem;
    text-align: center;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 5rem 0 4rem;
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    backdrop-filter: blur(10px);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 8px rgba(34, 197, 94, 0.5);
  }

  .hero-title {
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    max-width: 800px;
    background: linear-gradient(to bottom, #ffffff, #999999);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  html[lang="ar"] .hero-title {
    letter-spacing: 0;
    line-height: 1.2;
  }

  .hero-description {
    margin-top: 1.5rem;
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 560px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-lg {
    padding: 0.9rem 2rem;
    font-size: 0.95rem;
    border-radius: var(--radius-md);
  }

  /* RTL arrow flip */
  html[dir="rtl"] .hero-actions svg {
    transform: scaleX(-1);
  }

  .hero-glow {
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.06) 0%, transparent 65%);
    pointer-events: none;
    animation: glowPulse 8s ease-in-out infinite;
  }
</style>
