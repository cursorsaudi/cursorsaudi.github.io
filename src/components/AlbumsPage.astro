---
import { getEventsWithAlbums, getEventCoverUrl } from "@/utils/events";
import { getEventPartnersMap, getEventPartners, partnerRoleLabels } from "@/utils/people";
import type { EventPartnerEntry } from "@/utils/people";
import { config } from "@/config";
import type { CollectionEntry } from "astro:content";
import { localizedPath } from "@/utils/i18n-path";

const pagePath = Astro.url.pathname;

type EventEntry = CollectionEntry<"events">;

const albums = await getEventsWithAlbums();
const partnersMap = getEventPartnersMap();

type InviteWithPhotos = (typeof config.invites)[number] & { photos: string[] };
const invitesWithPhotos = config.invites
  .filter((i): i is InviteWithPhotos => "photos" in i && Array.isArray((i as any).photos) && (i as any).photos.length > 0)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
}

function formatDateAr(date: Date) {
  return date.toLocaleDateString("ar-SA", { year: "numeric", month: "short", day: "numeric" });
}

---

<section id="albums">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-12 md:py-20">

    <!-- List View -->
    <div id="albums-list">
      <div class="mb-16 border-b border-[#252525] pb-8">
        <h1 class="text-4xl md:text-5xl font-semibold text-white mb-4">
          <span class="lang-en">Albums</span>
          <span class="lang-ar">ألبومات</span>
        </h1>
        <p class="text-[#999999] text-lg max-w-xl">
          <span class="lang-en">Photos & videos from our past events</span>
          <span class="lang-ar">صور وفيديوهات من فعالياتنا السابقة</span>
        </p>
      </div>

      {albums.length === 0 ? (
        <div class="py-16 text-center">
          <svg class="mx-auto mb-6 text-[#555]" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <p class="text-[#999999] text-lg">
            <span class="lang-en">No albums yet</span>
            <span class="lang-ar">لا توجد ألبومات حالياً</span>
          </p>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {albums.map((event: EventEntry) => {
            const coverUrl = getEventCoverUrl(event);
            const photoCount = event.data.photos?.length ?? 0;
            const videoCount = event.data.videos?.length ?? 0;
            const eventPartners = getEventPartners(event.id, event.data.venue, partnersMap);
            return (
              <a
                href={localizedPath(pagePath, `/albums/${event.id}/`)}
                class="album-card bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden hover:border-white/20 transition-all group text-start cursor-pointer block"
              >
                <div class="aspect-[16/10] bg-[#1F1F1F] overflow-hidden">
                  {coverUrl ? (
                    <img
                      src={coverUrl}
                      alt={event.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-[#555]">
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                      </svg>
                    </div>
                  )}
                </div>
                <div class="p-5">
                  <h3 class="text-lg font-semibold text-white mb-1 group-hover:text-white transition-colors">
                    <span class="lang-en">{event.data.title}</span>
                    <span class="lang-ar">{event.data.titleAr || event.data.title}</span>
                  </h3>
                  <div class="flex items-center gap-3 text-xs text-[#999999]">
                    <span>
                      <span class="lang-en">{formatDate(event.data.date)}</span>
                      <span class="lang-ar">{formatDateAr(event.data.date)}</span>
                    </span>
                    <span class="text-[#555]">·</span>
                    <span>
                      {photoCount > 0 && (
                        <>
                          <span class="lang-en">{photoCount} photos</span>
                          <span class="lang-ar">{photoCount.toLocaleString("ar-SA")} صور</span>
                        </>
                      )}
                      {photoCount > 0 && videoCount > 0 && <span class="text-[#555]"> · </span>}
                      {videoCount > 0 && (
                        <>
                          <span class="lang-en">{videoCount} {videoCount === 1 ? 'video' : 'videos'}</span>
                          <span class="lang-ar">{videoCount.toLocaleString("ar-SA")} {videoCount === 1 ? 'فيديو' : 'فيديوهات'}</span>
                        </>
                      )}
                    </span>
                  </div>
                  <div class="flex items-center gap-1.5 text-xs text-[#6E6E6E] mt-2">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span class="lang-en">{event.data.location}{event.data.venue ? ` · ${event.data.venue}` : ''}</span>
                    <span class="lang-ar">{event.data.locationAr || event.data.location}{event.data.venue ? ` · ${event.data.venue}` : ''}</span>
                  </div>
                  {eventPartners.length > 0 && (
                    <div class="flex flex-wrap items-center gap-2 mt-2">
                      {eventPartners.map((p: EventPartnerEntry) => (
                        <span class="flex items-center gap-1.5 rounded-full bg-white/5 border border-[#252525] px-2 py-0.5">
                          <img src={p.logo} alt={p.name} class="w-4 h-4 object-contain" width="16" height="16" loading="lazy" />
                          <span class="text-[10px] text-[#8b949e] leading-tight">
                            <span class="lang-en">{partnerRoleLabels[p.role].en}</span>
                            <span class="lang-ar">{partnerRoleLabels[p.role].ar}</span>
                          </span>
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      )}

      {invitesWithPhotos.length > 0 && (
        <div class="mt-14">
          <h2 class="text-xs font-mono text-[#6E6E6E] uppercase tracking-widest mb-6">
            <span class="lang-en">External Invitations</span>
            <span class="lang-ar">دعوات خارجية</span>
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {invitesWithPhotos.map((invite) => {
              const inviteDate = new Date(invite.date);
              return (
                <button
                  class="invite-album-card bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden hover:border-white/20 transition-all group text-start cursor-pointer"
                  data-invite-title={invite.talkTitle}
                  type="button"
                >
                  <div class="aspect-[16/10] bg-[#1F1F1F] overflow-hidden">
                    <img
                      src={invite.photos[0]}
                      alt={invite.talkTitle}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-5">
                    <h3 class="text-lg font-semibold text-white mb-1 group-hover:text-white transition-colors">
                      <span class="lang-en">{invite.talkTitle}</span>
                      <span class="lang-ar">{invite.talkTitleAr}</span>
                    </h3>
                    <div class="flex items-center gap-3 text-xs text-[#999999]">
                      <span>
                        <span class="lang-en">{formatDate(inviteDate)}</span>
                        <span class="lang-ar">{formatDateAr(inviteDate)}</span>
                      </span>
                      <span class="text-[#555]">·</span>
                      <span>
                        <span class="lang-en">{invite.photos.length} {invite.photos.length === 1 ? 'photo' : 'photos'}</span>
                        <span class="lang-ar">{invite.photos.length.toLocaleString("ar-SA")} {invite.photos.length === 1 ? 'صورة' : 'صور'}</span>
                      </span>
                    </div>
                    <div class="flex items-center gap-1.5 text-xs text-[#6E6E6E] mt-2">
                      <span class="lang-en">{invite.speaker} · {invite.invitedBy}</span>
                      <span class="lang-ar">{invite.speakerAr} · {invite.invitedByAr}</span>
                    </div>
                  </div>
                </button>
              );
            })}
          </div>
        </div>
      )}
    </div>

    <!-- Invite Detail Views (one per invite album) -->
    {invitesWithPhotos.map((invite) => (
      <div class="invite-album-detail hidden" data-invite-detail={invite.talkTitle}>
        <button class="album-back-btn flex items-center gap-2 text-sm text-[#999999] hover:text-white transition-colors mb-8 cursor-pointer" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          <span class="lang-en">Back to Albums</span>
          <span class="lang-ar">العودة للألبومات</span>
        </button>

        <div class="mb-10 border-b border-[#252525] pb-8">
          <h1 class="text-3xl md:text-4xl font-semibold text-white mb-3">
            <span class="lang-en">{invite.talkTitle}</span>
            <span class="lang-ar">{invite.talkTitleAr}</span>
          </h1>
          <div class="flex flex-wrap items-center gap-4 text-sm text-[#999999] mb-4">
            <span class="flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span class="lang-en">{formatDate(new Date(invite.date))}</span>
              <span class="lang-ar">{formatDateAr(new Date(invite.date))}</span>
            </span>
            <span class="flex items-center gap-1.5">
              <span class="lang-en">{invite.speaker} · {invite.invitedBy}</span>
              <span class="lang-ar">{invite.speakerAr} · {invite.invitedByAr}</span>
            </span>
          </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
          {invite.photos.map((photo: string, idx: number) => (
            <button
              class="invite-album-media aspect-square bg-[#1F1F1F] rounded-xl overflow-hidden cursor-pointer border border-[#252525] hover:border-white/20 transition-all group relative"
              data-invite-name={invite.talkTitle}
              data-media-idx={idx}
              type="button"
            >
              <img
                src={photo}
                alt={`${invite.talkTitle} - ${idx + 1}`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </button>
          ))}
        </div>
      </div>
    ))}

  </div>

  <!-- Lightbox: scrollable overlay so tall media stays reachable while body overflow is locked -->
  <div id="album-lightbox" class="fixed inset-0 z-[100] hidden bg-black/90 backdrop-blur-sm overflow-x-hidden overflow-y-auto overscroll-contain">
    <div id="lightbox-backdrop" class="fixed inset-0 z-0" aria-hidden="true"></div>
    <div class="relative z-[1] flex min-h-[100dvh] w-full items-center justify-center px-4 py-20 sm:px-6 sm:py-24 box-border pointer-events-none">
      <img
        id="lightbox-img"
        class="relative z-[1] max-h-[min(85dvh,calc(100dvh-8rem))] max-w-[min(90vw,100%)] w-auto h-auto min-h-0 min-w-0 object-contain rounded-lg hidden shadow-2xl pointer-events-auto"
        src=""
        alt=""
      />
      <video
        id="lightbox-video"
        class="relative z-[1] max-h-[min(85dvh,calc(100dvh-8rem))] max-w-[min(90vw,100%)] w-auto h-auto min-h-0 min-w-0 object-contain rounded-lg hidden shadow-2xl pointer-events-auto"
        controls
        playsinline
      ></video>
    </div>
    <button id="lightbox-close" class="fixed top-4 end-4 z-[2] w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer" type="button" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button id="lightbox-prev" class="fixed start-4 top-1/2 -translate-y-1/2 z-[2] w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer" type="button" aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button id="lightbox-next" class="fixed end-4 top-1/2 -translate-y-1/2 z-[2] w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors cursor-pointer" type="button" aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div id="lightbox-counter" class="fixed bottom-4 left-1/2 -translate-x-1/2 z-[2] text-sm text-white/70 pointer-events-none"></div>
  </div>
</section>

<script is:inline>
  (function () {
    var listView = document.getElementById('albums-list');
    var inviteDetails = document.querySelectorAll('.invite-album-detail');
    var lightbox = document.getElementById('album-lightbox');
    var lightboxImg = document.getElementById('lightbox-img');
    var lightboxVideo = document.getElementById('lightbox-video');
    var lightboxCounter = document.getElementById('lightbox-counter');
    var currentMedia = [];
    var currentIdx = 0;

    function showInviteDetail(title) {
      if (listView) listView.classList.add('hidden');
      inviteDetails.forEach(function (d) { d.classList.add('hidden'); });
      var detail = document.querySelector('[data-invite-detail="' + title + '"]');
      if (detail) detail.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showAlbumsList() {
      inviteDetails.forEach(function (d) { d.classList.add('hidden'); });
      if (listView) listView.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    window.__albumsResetToList = showAlbumsList;

    document.querySelectorAll('.album-back-btn').forEach(function (btn) {
      btn.addEventListener('click', showAlbumsList);
    });

    document.querySelectorAll('.invite-album-card').forEach(function (card) {
      card.addEventListener('click', function () {
        var title = this.getAttribute('data-invite-title');
        if (title) showInviteDetail(title);
      });
    });

    document.querySelectorAll('.invite-album-media').forEach(function (el) {
      el.addEventListener('click', function () {
        var name = this.getAttribute('data-invite-name');
        var idx = parseInt(this.getAttribute('data-media-idx'), 10);
        var items = document.querySelectorAll('.invite-album-media[data-invite-name="' + name + '"]');
        currentMedia = [];
        items.forEach(function (item) {
          var img = item.querySelector('img');
          if (img) currentMedia.push({ src: img.getAttribute('src'), type: 'image' });
        });
        currentIdx = idx;
        updateLightbox();
        if (lightbox) lightbox.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    });

    function closeLightbox() {
      if (lightbox) lightbox.classList.add('hidden');
      document.body.style.overflow = '';
      if (lightboxVideo) { lightboxVideo.pause(); lightboxVideo.removeAttribute('src'); }
    }

    function updateLightbox() {
      var item = currentMedia[currentIdx];
      if (!item) return;
      if (item.type === 'video') {
        if (lightboxImg) lightboxImg.classList.add('hidden');
        if (lightboxVideo) { lightboxVideo.classList.remove('hidden'); lightboxVideo.setAttribute('src', item.src); lightboxVideo.load(); }
      } else {
        if (lightboxVideo) { lightboxVideo.pause(); lightboxVideo.classList.add('hidden'); }
        if (lightboxImg) { lightboxImg.classList.remove('hidden'); lightboxImg.setAttribute('src', item.src); lightboxImg.setAttribute('alt', 'Media ' + (currentIdx + 1)); }
      }
      if (lightboxCounter) lightboxCounter.textContent = (currentIdx + 1) + ' / ' + currentMedia.length;
    }

    function nextMedia() { if (lightboxVideo) lightboxVideo.pause(); currentIdx = (currentIdx + 1) % currentMedia.length; updateLightbox(); }
    function prevMedia() { if (lightboxVideo) lightboxVideo.pause(); currentIdx = (currentIdx - 1 + currentMedia.length) % currentMedia.length; updateLightbox(); }

    var closeBtn = document.getElementById('lightbox-close');
    var prevBtn = document.getElementById('lightbox-prev');
    var nextBtn = document.getElementById('lightbox-next');
    var backdropEl = document.getElementById('lightbox-backdrop');
    if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
    if (prevBtn) prevBtn.addEventListener('click', prevMedia);
    if (nextBtn) nextBtn.addEventListener('click', nextMedia);
    if (backdropEl) backdropEl.addEventListener('click', closeLightbox);

    document.addEventListener('keydown', function (e) {
      if (lightbox && !lightbox.classList.contains('hidden')) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowRight') nextMedia();
        if (e.key === 'ArrowLeft') prevMedia();
      }
    });
  })();
</script>
