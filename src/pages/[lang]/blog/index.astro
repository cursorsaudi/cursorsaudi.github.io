---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getAllBlogPosts, type BlogPost } from "@/utils/blog";
import { SITE_LOCALES, localizedPath } from "@/utils/i18n-path";

export async function getStaticPaths() {
  return SITE_LOCALES.map((lang) => ({ params: { lang } }));
}

const pagePath = Astro.url.pathname;
const posts: BlogPost[] = await getAllBlogPosts();

function typeLabel(type: string): { en: string; ar: string } {
  const labels: Record<string, { en: string; ar: string }> = {
    meetup: { en: "Meetup", ar: "لقاء" },
    hackathon: { en: "Hackathon", ar: "هاكاثون" },
    workshop: { en: "Workshop", ar: "ورشة عمل" },
    build: { en: "Build", ar: "بناء" },
    talk: { en: "Talk", ar: "محاضرة" },
    interview: { en: "Interview", ar: "مقابلة" },
  };
  return labels[type] ?? { en: type, ar: type };
}
---

<Layout title="Blog — Cursor Saudi" description="Event recaps and articles from the Cursor Saudi community.">
  <Header />
  <main id="main-content" class="flex-grow pt-[72px] relative z-10">
    <div class="max-w-4xl mx-auto px-6 md:px-10 py-12 md:py-20">
      <div class="mb-12 border-b border-[#252525] pb-8">
        <h1 class="text-4xl md:text-5xl font-semibold text-white mb-4">
          <span class="lang-en">Blog</span>
          <span class="lang-ar">المدونة</span>
        </h1>
        <p class="text-[#999999] text-lg">
          <span class="lang-en">Event recaps and articles from the community.</span>
          <span class="lang-ar">ملخصات الفعاليات ومقالات من المجتمع.</span>
        </p>
      </div>

      {posts.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-[#999999] text-lg">
            <span class="lang-en">No posts yet.</span>
            <span class="lang-ar">لا توجد تدوينات بعد.</span>
          </p>
        </div>
      ) : (
        <div class="flex flex-col gap-6">
          {posts.map((post) => {
            const href = localizedPath(pagePath, `/blog/${post.slug}/`);
            const dateEn = post.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
            const dateAr = post.date.toLocaleDateString("ar-SA", { month: "short", day: "numeric", year: "numeric" });
            return (
              <a href={href} class="group bg-[#171717] border border-[#252525] rounded-2xl overflow-hidden hover:border-white/20 transition-all flex flex-col sm:flex-row">
                {post.coverImage && (
                  <div class="sm:w-48 sm:shrink-0 aspect-[16/10] sm:aspect-auto bg-[#0d1117]">
                    <img
                      src={post.coverImage}
                      alt=""
                      class="w-full h-full object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="p-6 flex flex-col flex-grow min-w-0">
                  <div class="flex items-center gap-2 mb-3">
                    {post.source === "event" ? (
                      <span class="text-[10px] font-mono text-[#58a6ff] border border-[#58a6ff]/25 bg-[#58a6ff]/10 rounded px-2 py-0.5 uppercase tracking-wider">
                        <span class="lang-en">Event recap</span>
                        <span class="lang-ar">ملخص فعالية</span>
                      </span>
                    ) : (
                      <span class="text-[10px] font-mono text-green-400 border border-green-400/25 bg-green-400/10 rounded px-2 py-0.5 uppercase tracking-wider">
                        <span class="lang-en">Article</span>
                        <span class="lang-ar">مقال</span>
                      </span>
                    )}
                    {post.eventType && (
                      <span class="text-[10px] font-mono text-[#6E6E6E] border border-[#252525] rounded px-2 py-0.5 uppercase tracking-wider">
                        <span class="lang-en">{typeLabel(post.eventType).en}</span>
                        <span class="lang-ar">{typeLabel(post.eventType).ar}</span>
                      </span>
                    )}
                    <span class="text-xs text-[#6E6E6E]">
                      <span class="lang-en">{dateEn}</span>
                      <span class="lang-ar">{dateAr}</span>
                    </span>
                  </div>
                  <h2 class="text-lg font-semibold text-white group-hover:text-[#79c0ff] transition-colors mb-2">
                    <span class="lang-en">{post.title}</span>
                    <span class="lang-ar">{post.titleAr || post.title}</span>
                  </h2>
                  <p class="text-sm text-[#999999] line-clamp-2">
                    <span class="lang-en">{post.description}</span>
                    <span class="lang-ar">{post.descriptionAr || post.description}</span>
                  </p>
                  {post.eventLocation && (
                    <div class="flex items-center gap-1.5 text-xs text-[#6E6E6E] mt-3">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                      <span class="lang-en">{post.eventLocation}</span>
                      <span class="lang-ar">{post.eventLocationAr || post.eventLocation}</span>
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout>
