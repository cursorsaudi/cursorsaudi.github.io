---
/** Unprefixed `/` → default locale (`/ar/`). Cloudflare `public/_redirects` also 302s here. */
const siteOrigin = Astro.site?.origin ?? "https://cursorsaudi.com";
const target = `${siteOrigin}/ar/`;
---
<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Cursor Saudi</title>
    <link rel="canonical" href={target} />
    <meta http-equiv="refresh" content="0;url=/ar/" />
  </head>
  <body>
    <a href="/ar/">Cursor Saudi — /ar/</a>
  </body>
</html>
